{
  "info": {
    "name": "Backup Inventory Investigation API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Obtain JWT Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"jwt-auditor\",\n  \"password\": \"StrongPass123!\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/token/",
          "protocol": "http",
          "host": [
            "127",
            "0",
            "0",
            "1"
          ],
          "port": "8000",
          "path": [
            "api",
            "token"
          ]
        }
      }
    },
    {
      "name": "2. Get Investigation Payload",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/investigation/{{exception_id}}/",
          "protocol": "http",
          "host": [
            "127",
            "0",
            "0",
            "1"
          ],
          "port": "8000",
          "path": [
            "api",
            "investigation",
            "{{exception_id}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "exception_id",
      "value": "EXC-00000000"
    }
  ]
}
